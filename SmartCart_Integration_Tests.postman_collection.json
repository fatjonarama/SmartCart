      "name": "0. SETUP — Admin Login",
      "item": [
        {
          "name": "0.1 Admin Login (ruaj token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Ka accessToken', () => {",
                  "  const b = pm.response.json();",
                  "  pm.expect(b).to.have.property('accessToken');",
                  "  pm.collectionVariables.set('accessToken', b.accessToken);",
                  "  pm.collectionVariables.set('adminToken', b.accessToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@smartcart.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
